<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Modern POM Smoke Suite" parallel="tests" thread-count="2">
    
    <listeners>
        <listener class-name="com.modern.automation.utils.TestListener"/>
    </listeners>

    <test name="Smoke Tests - Chrome">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="smokeTest"/>
            </run>
        </groups>
        <classes>
            <class name="com.modern.automation.tests.LoginTest"/>
            <class name="com.modern.automation.tests.DashboardTest"/>
        </classes>
    </test>

</suite>
